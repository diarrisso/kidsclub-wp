{
    "name": "zacp/kidsclub-theme",
    "description": "Kids Club by zacp — WordPress theme (Kinderzahnarztpraxis Osnabrück)",
    "type": "wordpress-theme",
    "license": "proprietary",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/acf-pro-stubs": "^6.0",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1"
    },
    "scripts": {
        "test": [
            "@lint",
            "@stan"
        ],
        "lint": "find . -name '*.php' -not -path './vendor/*' -exec php -l {} \\; | grep -v 'No syntax errors' || true",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs": "phpcs",
        "format": "phpcbf || true"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
